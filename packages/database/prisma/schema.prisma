generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  creator
  talent_manager
  brand
  admin
}

enum ProfileState {
  unclaimed
  pending_claim
  claimed
  premium
}

enum Platform {
  twitch
  youtube
  instagram
  tiktok
  x
  kick
}

enum SnapshotTier {
  tier1
  tier2
  tier3
}

enum ClaimMethod {
  oauth
  cross_platform
  bio_challenge
  post_challenge
  manual_review
}

enum ClaimStatus {
  pending
  approved
  rejected
  expired
}

// ============================================================
// AUTH & USERS
// ============================================================

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          UserRole  @default(creator)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  creatorProfile  CreatorProfile?
  managedCreators TalentManagerAccess[] @relation("ManagerToCreator")
  claimRequests   ClaimRequest[]
}

model Account {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String  @db.Uuid
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// CREATOR PROFILES
// ============================================================

model CreatorProfile {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String?      @unique @db.Uuid
  user           User?        @relation(fields: [userId], references: [id])
  state          ProfileState @default(unclaimed)
  snapshotTier   SnapshotTier @default(tier3)

  displayName    String
  slug           String       @unique
  avatarUrl      String?
  bannerUrl      String?
  bio            String?
  country        String?

  primaryPlatform Platform

  totalFollowers BigInt @default(0)
  totalViews     BigInt @default(0)
  searchText     String? @default("")

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastSnapshotAt DateTime?
  claimedAt      DateTime?

  platformAccounts  PlatformAccount[]
  metricSnapshots   MetricSnapshot[]
  claimRequests     ClaimRequest[]
  talentAccess      TalentManagerAccess[]
  brandPartnerships BrandPartnership[]
  growthRollups     CreatorGrowthRollup[]

  @@index([state])
  @@index([snapshotTier])
  @@index([primaryPlatform])
  @@index([totalFollowers(sort: Desc)])
}

// ============================================================
// PLATFORM ACCOUNTS
// ============================================================

model PlatformAccount {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  creatorProfileId String         @db.Uuid
  creatorProfile   CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  platform            Platform
  platformUserId      String
  platformUsername    String
  platformDisplayName String?
  platformUrl         String?
  platformAvatarUrl   String?

  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  oauthScopes    String[] @default([])

  isOAuthConnected Boolean   @default(false)
  lastOAuthRefresh DateTime?

  followerCount   BigInt?
  followingCount  BigInt?
  totalViews      BigInt?
  subscriberCount BigInt?
  postCount       Int?

  lastSyncedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([platform, platformUserId])
  @@unique([creatorProfileId, platform])
  @@index([platform])
  @@index([platformUsername])
}

// ============================================================
// METRIC SNAPSHOTS
// ============================================================

model MetricSnapshot {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  creatorProfileId String         @db.Uuid
  creatorProfile   CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  platform        Platform
  snapshotAt      DateTime @default(now())
  followerCount   BigInt?
  followingCount  BigInt?
  totalViews      BigInt?
  subscriberCount BigInt?
  postCount       Int?
  extendedMetrics Json?

  @@index([creatorProfileId, platform, snapshotAt])
  @@index([snapshotAt])
}

// ============================================================
// CLAIM REQUESTS
// ============================================================

model ClaimRequest {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  creatorProfileId String         @db.Uuid
  creatorProfile   CreatorProfile @relation(fields: [creatorProfileId], references: [id])
  userId           String         @db.Uuid
  user             User           @relation(fields: [userId], references: [id])

  method   ClaimMethod
  status   ClaimStatus @default(pending)
  platform Platform

  challengeCode      String?   @unique
  challengeExpiresAt DateTime?

  evidenceUrls String[]  @default([])
  reviewNotes  String?
  reviewedBy   String?   @db.Uuid
  reviewedAt   DateTime?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?

  @@index([creatorProfileId])
  @@index([userId])
  @@index([status])
}

// ============================================================
// TALENT MANAGER ACCESS
// ============================================================

model TalentManagerAccess {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  managerId        String         @db.Uuid
  manager          User           @relation("ManagerToCreator", fields: [managerId], references: [id])
  creatorProfileId String         @db.Uuid
  creatorProfile   CreatorProfile @relation(fields: [creatorProfileId], references: [id])

  canViewAnalytics Boolean @default(true)
  canEditProfile   Boolean @default(false)
  canExportData    Boolean @default(false)
  canManageBrands  Boolean @default(false)

  grantedAt DateTime  @default(now())
  grantedBy String    @db.Uuid
  revokedAt DateTime?

  @@unique([managerId, creatorProfileId])
  @@index([managerId])
}

// ============================================================
// BRAND PARTNERSHIPS
// ============================================================

model BrandPartnership {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  creatorProfileId String         @db.Uuid
  creatorProfile   CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  brandName    String
  brandLogoUrl String?
  campaignName String?
  startDate    DateTime?
  endDate      DateTime?
  isPublic     Boolean  @default(true)

  createdAt DateTime @default(now())
}

// ============================================================
// GAMES & CATEGORIES
// ============================================================

model Game {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  twitchGameId  String? @unique
  igdbId        Int?    @unique
  youtubeGameId String?

  name          String
  slug          String   @unique
  coverImageUrl String?
  summary       String?
  releaseDate   DateTime?
  genres        String[] @default([])
  platforms     String[] @default([])
  developer     String?
  publisher     String?

  searchText      String? @default("")

  currentViewers  Int    @default(0)
  currentChannels Int    @default(0)
  peakViewers24h  Int    @default(0)
  avgViewers7d    Int    @default(0)
  hoursWatched7d  BigInt @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  viewerSnapshots GameViewerSnapshot[]

  @@index([currentViewers(sort: Desc)])
  @@index([name])
}

model GameViewerSnapshot {
  id     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gameId String   @db.Uuid
  game   Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  snapshotAt DateTime @default(now())

  twitchViewers  Int @default(0)
  twitchChannels Int @default(0)
  youtubeViewers Int @default(0)
  youtubeChannels Int @default(0)
  kickViewers    Int @default(0)
  kickChannels   Int @default(0)
  totalViewers   Int @default(0)
  totalChannels  Int @default(0)

  @@index([gameId, snapshotAt])
  @@index([snapshotAt])
}

// ============================================================
// CREATOR GROWTH ROLLUPS
// ============================================================

model CreatorGrowthRollup {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  creatorProfileId String         @db.Uuid
  creatorProfile   CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  platform         Platform

  followerCount    BigInt   @default(0)
  delta1d          BigInt   @default(0)
  delta7d          BigInt   @default(0)
  delta30d         BigInt   @default(0)
  pct1d            Float    @default(0)
  pct7d            Float    @default(0)
  pct30d           Float    @default(0)

  trendDirection   String   @default("FLAT")
  acceleration     String   @default("STABLE")

  computedAt       DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([creatorProfileId, platform])
  @@index([trendDirection])
  @@index([delta7d(sort: Desc)])
}
