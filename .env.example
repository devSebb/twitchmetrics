# ============================================================
# DATABASE — Supabase PostgreSQL
# ============================================================
# Pooled connection via Supavisor (port 6543) — used for queries
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) — used for migrations only
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ============================================================
# SUPABASE — for Realtime features (future)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ============================================================
# AUTH — Auth.js v5 (NextAuth)
# ============================================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""  # Generate: openssl rand -base64 32

# ============================================================
# OAUTH PROVIDERS
# ============================================================

# Twitch — https://dev.twitch.tv/console
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""
TWITCH_EVENTSUB_SECRET=""  # For webhook signature verification

# Google / YouTube — https://console.cloud.google.com
# Enable: YouTube Data API v3 + YouTube Analytics API
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
YOUTUBE_API_KEY=""  # For public data fetching (no OAuth needed)

# Instagram / Meta — https://developers.facebook.com
# Requires: Instagram Graph API + Business account linked to Facebook Page
INSTAGRAM_APP_ID=""
INSTAGRAM_APP_SECRET=""

# TikTok — https://developers.tiktok.com
# Requires: Login Kit + Display API approval
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# X / Twitter — https://developer.twitter.com
# Basic tier ($100/mo) minimum for read access
TWITTER_CLIENT_ID=""
TWITTER_CLIENT_SECRET=""
TWITTER_BEARER_TOKEN=""  # For app-only auth (public data)

# Kick — TBD
KICK_CLIENT_ID=""
KICK_CLIENT_SECRET=""

# ============================================================
# UPSTASH REDIS — Rate limiting + caching
# ============================================================
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ============================================================
# INNGEST — Background job processing
# ============================================================
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ============================================================
# CLOUDFLARE R2 — File storage (banners, media kit assets)
# ============================================================
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="twitchmetrics-media"
NEXT_PUBLIC_R2_PUBLIC_URL=""

# ============================================================
# SECURITY
# ============================================================
# 32-byte hex key for AES-256-GCM OAuth token encryption
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=""
